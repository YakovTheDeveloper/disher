// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

enum ScheduleItemType {
  food
  dish
  custom
}

enum ScheduleEventType {
  negative
  positive
  custom
  routine
  sport
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator zod {
  provider = "zod-prisma-types"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  id        String          @id // DD-MM-YYYY
  items     ScheduleItem[]
  events    ScheduleEvent[]
  userId    Int
  user      User            @relation(fields: [userId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ScheduleEvent {
  id         String            @id
  type       ScheduleEventType
  time       String
  scheduleId String
  schedule   Schedule          @relation(fields: [scheduleId], references: [id])
  value      String
}

model ScheduleItem {
  id             String           @id
  quantity       Int
  type           ScheduleItemType
  time           String
  customFoodName String?
  foodId         Int?
  dishId         String?
  scheduleId     String
  food           Food?            @relation(fields: [foodId], references: [id])
  dish           Dish?            @relation(fields: [dishId], references: [id])
  schedule       Schedule         @relation(fields: [scheduleId], references: [id])
}

model Food {
  id             Int            @id @default(autoincrement())
  name           String
  nameEng        String
  description    String?
  descriptionEng String?
  nutrients      FoodNutrient[]
  ScheduleItem   ScheduleItem[]
  DishItem       DishItem[]
}

model FoodNutrient {
  id         Int      @id @default(autoincrement())
  quantity   Float
  foodId     Int
  Food       Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  nutrientId Int
  Nutrient   Nutrient @relation(fields: [nutrientId], references: [id])
}

model Nutrient {
  id             Int            @id @default(autoincrement())
  name           String?
  nameEng        String?
  unit           String?
  unitEng        String?
  displayName    String?
  displayNameEng String?
  FoodNutrient   FoodNutrient[]
  DailyNormItem  DailyNormItem?
}

model Dish {
  name         String
  id           String         @id
  items        DishItem[]
  userId       Int
  user         User           @relation(fields: [userId], references: [id])
  ScheduleItem ScheduleItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model DishItem {
  id       String @id
  quantity Int
  foodId   Int
  dishId   String
  food     Food   @relation(fields: [foodId], references: [id])
  dish     Dish   @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

model DailyNorm {
  id          Int             @id @default(autoincrement())
  items       DailyNormItem[]
  userId      Int
  user        User            @relation(fields: [userId], references: [id])
  name        String
  description String
}

model DailyNormItem {
  id         Int       @id @default(autoincrement())
  normId     Int
  norm       DailyNorm @relation(fields: [normId], references: [id], onDelete: Cascade)
  nutrientId Int       @unique
  Nutrient   Nutrient  @relation(fields: [nutrientId], references: [id])
  quantity   Int?
}

