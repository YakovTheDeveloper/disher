{
  "name": "@disher/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/free-port.mjs 5173 && vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev-local": "node scripts/free-port.mjs 5173 && vite --port 5173 --strictPort",
    "dev-network": "node scripts/free-port.mjs 5173 && vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev:e2e": "node scripts/free-port.mjs 4173 && cross-env VITE_HOST=127.0.0.1 VITE_PORT=4173 VITE_E2E_HTTP=1 VITE_BACKEND_PORT=3101 vite --mode test --host 127.0.0.1 --port 4173 --strictPort",
    "free-port": "node scripts/free-port.mjs",
    "build": "vite build",
    "preview": "vite preview --host",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "check:tokens": "node scripts/check-scale-tokens.mjs && node scripts/check-dead-token-refs.mjs && node scripts/check-selected-token.mjs && node scripts/check-text-role.mjs && node scripts/check-token-naming.mjs && node scripts/check-apca-contrast.mjs && node scripts/check-typo-encapsulation.mjs && node scripts/check-surface-token.mjs && node scripts/check-token-tier.mjs",
    "lint:style": "node scripts/check-scale-tokens.mjs && node scripts/check-dead-token-refs.mjs && node scripts/check-selected-token.mjs && node scripts/check-text-role.mjs && node scripts/check-token-naming.mjs && node scripts/check-apca-contrast.mjs && node scripts/check-typo-encapsulation.mjs && node scripts/check-surface-token.mjs && node scripts/check-token-tier.mjs && stylelint \"src/**/*.{scss,css}\" --max-warnings 0",
    "check:precache": "node scripts/check-precache.mjs",
    "lint:style:baseline": "node scripts/gen-stylelint-baseline.mjs",
    "check:typo:baseline": "cross-env TYPO_BASELINE_REGEN=1 node scripts/check-typo-encapsulation.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo tsconfig.tsbuildinfo",
    "create-component": "node create-boilerplate-component.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@floating-ui/react": "0.27.0",
    "@fontsource-variable/onest": "^5.2.11",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "@sentry/react": "^10.50.0",
    "@zumer/snapdom": "^2.12.8",
    "better-auth": "1.6.9",
    "clsx": "2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "4.4.2",
    "dexie-react-hooks": "4.4.0",
    "embla-carousel-react": "^8.6.0",
    "fuse.js": "^7.1.0",
    "i18next": "^25.8.1",
    "idb-keyval": "^6.2.2",
    "mitt": "^3.0.1",
    "motion": "^12.23.12",
    "react": "^19.1.1",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.1",
    "react-router-dom": "^7.9.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "uuid": "^11.0.3",
    "vite-plugin-checker": "^0.12.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.7.0",
    "jiti": "^2.5.1",
    "jsdom": "^25.0.1",
    "kill-port": "^2.0.1",
    "postcss-scss": "^4.0.9",
    "prettier": "3.6.2",
    "sass": "^1.81.0",
    "sharp": "^0.34.5",
    "stylelint": "^16",
    "stylelint-declaration-strict-value": "^1.11.1",
    "supabase": "^2.95.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.41.0",
    "vconsole": "^3.15.1",
    "vite": "~6.3.4",
    "vite-css-modules": "^1.10.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.2.4",
    "workbox-window": "^7.4.0"
  },
  "lint-staged": {
    "*.{scss,css}": [
      "node scripts/check-scale-tokens.mjs",
      "node scripts/check-dead-token-refs.mjs",
      "node scripts/check-selected-token.mjs",
      "node scripts/check-text-role.mjs",
      "node scripts/check-token-tier.mjs",
      "node scripts/check-surface-token.mjs",
      "stylelint"
    ],
    "vite.config.ts": [
      "node scripts/check-precache.mjs"
    ]
  }
}