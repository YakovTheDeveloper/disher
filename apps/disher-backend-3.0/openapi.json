    "/api/user-reports/": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "text"
                ],
                "additionalProperties": false,
                "properties": {
                  "text": {
                    "type": "string"
                  },
                  "page": {
                    "type": "string"
                  },
                  "screenSize": {
                    "type": "string"
                  },
                  "userAgent": {
                    "type": "string"
                  },
                  "pwa": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
