{
  "name": "disher-backend-3.0",
  "version": "1.0.0",
  "description": "Disher backend powered by Triplit",
  "type": "module",
  "scripts": {
    "predev": "npx --yes kill-port 6543 6544 3100 && tsx scripts/gen-anon-token.ts",
    "dev": "triplit dev --storage sqlite",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "console": "tsx scripts/console.ts",
    "schema:push": "triplit schema push",
    "seed": "tsx scripts/seed.ts",
    "reseed": "tsx scripts/reseed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@triplit/client": "^1.0.50",
    "fastify": "^5.2.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "@triplit/cli": "^1.0.61",
    "@triplit/console": "^1.0.52",
    "@types/node": "^25.5.0",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.1.0",
    "dotenv": "^17.3.1",
    "lmdb": "^3.5.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}