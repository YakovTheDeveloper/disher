{
  "name": "@disher/backend",
  "version": "1.0.0",
  "description": "Disher backend API server",
  "type": "module",
  "scripts": {
    "generate:certs": "tsx scripts/generate-certs.ts",
    "dev": "node scripts/free-port.mjs 3100 && tsx watch src/api/server.ts",
    "dev:network": "node scripts/free-port.mjs 3100 && cross-env HOST=0.0.0.0 tsx watch src/api/server.ts",
    "dev:e2e": "node scripts/free-port.mjs 3101 && cross-env HOST=127.0.0.1 PORT=3101 BACKEND_E2E_HTTP=1 NODE_ENV=test REQUIRE_EMAIL_VERIFICATION=true FRONTEND_ORIGIN=http://127.0.0.1:4173 BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173 tsx src/api/server.ts",
    "free-port": "node scripts/free-port.mjs",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/api/server.js",
    "lint": "echo 'no lint configured for backend'",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo tsconfig.tsbuildinfo",
    "spec:dump": "cross-env NODE_ENV=production tsx scripts/dump-openapi.ts",
    "spec:check": "cross-env NODE_ENV=production tsx scripts/dump-openapi.ts --check",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:reset:test": "tsx scripts/db-reset.ts --target=test --yes --quiet",
    "db:reset:remote": "tsx scripts/db-reset.ts --target=remote",
    "build:catalog": "tsx scripts/build-catalog.ts",
    "probe:matcher": "tsx scripts/probe-matcher.ts",
    "probe:matcher:basic": "tsx scripts/probe-matcher.ts --set=basic",
    "probe:matcher:tricky": "tsx scripts/probe-matcher.ts --set=tricky",
    "probe:matcher:oov": "tsx scripts/probe-matcher.ts --set=oov",
    "probe:coverage": "tsx scripts/probe-coverage.ts",
    "probe:parse": "tsx scripts/probe-parse.ts",
    "probe:recipe": "tsx scripts/probe-recipe.ts",
    "mine:queries": "tsx scripts/mine-queries.ts",
    "analyze:logs": "tsx scripts/analyze-logs.ts"
  },
  "dependencies": {
    "@disher/contracts": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.52",
    "@xenova/transformers": "^2.17.2",
    "better-auth": "1.6.9",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.2.0",
    "pg": "^8.20.0",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "kill-port": "^2.0.1",
    "lmdb": "^3.5.2",
    "selfsigned": "^5.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}