{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/api/server.ts",
    "scripts/*.ts",
    "src/**/__tests__/**/*.test.ts",
    "src/test/**/*.ts"
  ],
  "project": ["src/**/*.ts", "scripts/**/*.ts"],
  "ignore": [
    "dist/**",
    "db/**",
    "seed/**"
  ],
  "ignoreDependencies": [
    "concurrently",
    "selfsigned",
    "lmdb"
  ],
  "vitest": {
    "config": "vitest.config.ts"
  }
}
