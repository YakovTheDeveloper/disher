# ─────────────────────────────────────────────────────────────────────────────
# disher production env — TEMPLATE. Copy to `.env.production` (gitignored) on the
# VPS and fill in real values. DELIVER OUT-OF-BAND (scp), never commit secrets.
#
#   scp apps/disher-backend-3.0/.env.production user@vps:/srv/disher/.env.production
#
# Pinned in docker-compose.yml `environment:` — do NOT set here (would be ignored
# for the backend anyway): NODE_ENV, HOST, PORT, MODEL_CACHE_DIR, ANALYTICS_DB_PATH.
# ─────────────────────────────────────────────────────────────────────────────

# ── Caddy (TLS ingress) ──────────────────────────────────────────────────────
API_DOMAIN=api.example.com
ACME_EMAIL=you@example.com
# SPA_DOMAIN=app.example.com   # only if hosting the SPA from the same Caddy

# ── Postgres (the `postgres` service) ────────────────────────────────────────
POSTGRES_USER=disher
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=disher

# ── Backend → Postgres ───────────────────────────────────────────────────────
# MUST match POSTGRES_* above; host is the compose service name. better-auth and
# /api/backup both read LOCAL_DATABASE_URL; leave REMOTE_DATABASE_URL UNSET so
# both pools hit this one database.
LOCAL_DATABASE_URL=postgres://disher:change-me-strong-random@postgres:5432/disher
# REMOTE_DATABASE_URL=   # leave unset in prod

# ── Auth (better-auth, bearer) ───────────────────────────────────────────────
# Generate the secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32
BETTER_AUTH_URL=https://api.example.com
# CSV of exact SPA origins allowed to call the API (CORS + auth origin check).
BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com
FRONTEND_ORIGIN=https://app.example.com

# ── Auth: Telegram login (OIDC via oauth.telegram.org) ───────────────────────
# OPTIONAL. "Log in with Telegram" turns ON only when BOTH are set (server-side).
# Setup: open @BotFather as a Mini App → Bot Settings → Web Login → "Switch to
# OpenID Connect Login" (⚠ ONE-WAY, and the secret currently can't be rotated —
# prototype with a THROWAWAY bot). Register this exact Redirect URI as an
# Allowed URL: ${BETTER_AUTH_URL}/api/auth/oauth2/callback/telegram
# (localhost / raw LAN IPs are rejected — use an HTTPS tunnel in dev).
# The CLIENT SECRET is server-only — never ship it in the SPA bundle.
# TELEGRAM_CLIENT_ID=          # the bot's OIDC client_id (bot_id)
# TELEGRAM_CLIENT_SECRET=      # the bot's OIDC client secret

# ── LLM (OpenRouter) ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# SUGGESTION_MODEL=deepseek/deepseek-v4-flash   # optional override

# ── Email (Resend) ───────────────────────────────────────────────────────────
# RESEND_FROM must be on a VERIFIED Resend domain before flipping verification on
# (the sandbox onboarding@resend.dev only delivers to the account owner). See the
# Resend step in DEPLOY.md.
RESEND_API_KEY=re_...
RESEND_FROM=noreply@example.com
# Start at false; flip to true ONLY after the Resend domain is verified.
REQUIRE_EMAIL_VERIFICATION=false

# ── Optional tuning (sane defaults in code; uncomment to override) ────────────
# FREE_TEXT_RATE_LIMIT=30        # per IP / hour
# SUGGESTIONS_RATE_LIMIT=30      # per IP / hour
# TELEMETRY_RATE_LIMIT=60        # per IP / hour
# ALLOW_REMOTE_MODELS=false      # escape hatch; keep false (model is baked in)

# ─────────────────────────────────────────────────────────────────────────────
# SPA BUILD-TIME var (NOT a container env — set it when building the frontend):
#   VITE_API_BASE=https://api.example.com  pnpm --filter @disher/frontend build
# ─────────────────────────────────────────────────────────────────────────────
