{
  "name": "@disher/contracts",
  "version": "1.0.0",
  "description": "Shared client↔server contracts as TypeBox schemas (one declaration, both apps derive types from Static<>)",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured for contracts'",
    "test": "echo 'no tests in contracts'",
    "clean": "rimraf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.52"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "typescript": "^5.9.3"
  }
}
